{
  "name": "opentui-island",
  "version": "0.0.0",
  "private": true,
  "description": "Core primitives for hosting OpenTUI component trees inside foreign terminal UI runtimes.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pi-tui": {
      "types": "./dist/pi-tui.d.ts",
      "import": "./dist/pi-tui.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json",
    "build": "tsc -p tsconfig.build.json",
    "smoke": "bun examples/smoke.tsx",
    "smoke:pi-tui": "bun examples/pi-tui-smoke.tsx",
    "demo:pi-tui": "bun examples/pi-tui-live.tsx"
  },
  "devDependencies": {
    "@mariozechner/pi-tui": "^0.65.2",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-tui": "^0.65.2",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "react": "^19.2.4"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-tui": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
