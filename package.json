{
  "name": "opentui-island",
  "version": "0.1.0",
  "description": "Embed OpenTUI islands inside Node host terminal UIs like pi-tui and Ink via a Bun sidecar.",
  "keywords": [
    "bun",
    "ink",
    "opentui",
    "pi-tui",
    "react",
    "sidecar",
    "terminal",
    "tui"
  ],
  "homepage": "https://github.com/benvinegar/opentui-island#readme",
  "bugs": {
    "url": "https://github.com/benvinegar/opentui-island/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benvinegar/opentui-island.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pi-tui": {
      "types": "./dist/adapters/pi-tui/index.d.ts",
      "import": "./dist/adapters/pi-tui/index.js"
    },
    "./ink": {
      "types": "./dist/adapters/ink/index.d.ts",
      "import": "./dist/adapters/ink/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "check": "bun run lint && bun run lint:slop && bun run format:check && bun run typecheck && bun run typecheck:examples",
    "check:pack": "npm pack --json --dry-run",
    "lint": "oxlint . --deny-warnings",
    "lint:slop": "slop-scan scan . --lint && bun run lint:slop:check",
    "lint:slop:check": "slop-scan scan . --json | node scripts/check-slop-findings.mjs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check:node-imports": "node --input-type=module -e \"await import('./dist/index.js'); await import('./dist/adapters/pi-tui/index.js'); await import('./dist/adapters/ink/index.js')\"",
    "test": "bun test",
    "smoke": "bun run build && node ./examples/smoke.mjs",
    "smoke:ink": "bun run build && node ./examples/ink-smoke.mjs",
    "smoke:pi-tui": "bun run build && node ./examples/pi-tui-smoke.mjs",
    "demo:pi-tui": "bun run build && node ./examples/pi-tui-live.mjs",
    "demo:ink": "bun run build && node ./examples/ink-live.mjs",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check && bun test && bun run build && bun run check:node-imports"
  },
  "devDependencies": {
    "@mariozechner/pi-tui": "^0.65.2",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.14",
    "ink": "^7.0.0",
    "ink-testing-library": "^4.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "react": "^19.2.4",
    "simple-git-hooks": "^2.13.1",
    "slop-scan": "^0.1.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-tui": "^0.65.2",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "ink": "^7.0.0",
    "react": "^19.2.4"
  },
  "peerDependenciesMeta": {
    "ink": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "bun run check"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10"
}
